# =============================================================================
# Video Recap Agent — Production Environment Variables
# =============================================================================
# Copy to .env and fill in real values before deploying.
# NEVER commit the actual .env file to version control.

# --- Database ---
# These are overridden in docker-compose.yml environment section,
# but set strong credentials here for production.
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/video_recap

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_BUCKET=video-recaps
S3_REGION=us-east-1
# Public endpoint for presigned download URLs (must be reachable from user's browser)
# Use your domain or VPS IP, routed through Nginx /storage/ path
S3_PUBLIC_ENDPOINT=http://YOUR_VPS_IP_OR_DOMAIN/storage

# --- JWT Auth ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_GENERATE_A_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=

# --- Stripe Billing (optional, needed for paid tiers) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
WHISPER_MODEL_SIZE=small
# Use "tiny" if VPS has < 8GB RAM to reduce memory usage
model=gpt-4

# --- CORS ---
# Set to your production frontend URL
CORS_ORIGINS=["http://YOUR_VPS_IP_OR_DOMAIN"]

# --- File Upload ---
MAX_UPLOAD_SIZE_BYTES=2147483648

# --- Docker Port Bindings (production) ---
# Bind to localhost only; Nginx proxies public traffic
POSTGRES_PORT=127.0.0.1:5434
REDIS_PORT=127.0.0.1:6380
MINIO_API_PORT=127.0.0.1:9100
MINIO_CONSOLE_PORT=127.0.0.1:9101
BACKEND_PORT=127.0.0.1:8100
FRONTEND_PORT=127.0.0.1:3100

# --- MinIO Credentials (used in docker-compose minio service) ---
MINIO_ROOT_USER=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET_KEY

# --- Postgres Credentials (used in docker-compose postgres service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ===== User API Keys (OpenAI & AssemblyAI) =====
# Allow users to provide their own API keys
ENABLE_USER_API_KEYS=true
# Comma-separated list of emails allowed to use their own OpenAI keys
API_KEY_ALLOWED_EMAILS=[]

# ===== AssemblyAI Speaker Diarization =====
ASSEMBLYAI_API_KEY=
REQUIRE_ASSEMBLYAI_KEY=True
ENABLE_ASSEMBLYAI_DIARIZATION=true
ASSEMBLYAI_LANGUAGE_CODE=en
