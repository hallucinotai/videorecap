      { "id": "u1",  "start": 4.2,   "end": 7.1,   "text": "Hey, you made it. I was starting to think you'd bailed.",         "speaker": "A", "confidence": 0.94 },
      { "id": "u2",  "start": 7.4,   "end": 10.8,  "text": "I'm Sarah, sorry — traffic was a nightmare on Fifth.",            "speaker": "B", "confidence": 0.92 },
      { "id": "u3",  "start": 12.1,  "end": 15.6,  "text": "I'm James, by the way. We've never actually met in person.",      "speaker": "A", "confidence": 0.95 },
      { "id": "u4",  "start": 34.0,  "end": 39.2,  "text": "So… the offer. They want an answer by Monday.",                   "speaker": "B", "confidence": 0.93 },
      { "id": "u5",  "start": 40.0,  "end": 45.8,  "text": "Sarah, this is huge. Director of Engineering at twenty-nine?",    "speaker": "A", "confidence": 0.94 },
      { "id": "u6",  "start": 46.5,  "end": 52.1,  "text": "I know, I know. But it means moving to Singapore. Alone.",        "speaker": "B", "confidence": 0.91 },
      { "id": "u7",  "start": 80.3,  "end": 82.0,  "text": "Hold on, my phone…",                                              "speaker": "B", "confidence": 0.89 },
      { "id": "u8",  "start": 83.5,  "end": 90.4,  "text": "What?! When? Is she okay? I'll be there in twenty minutes.",      "speaker": "B", "confidence": 0.88 },
      { "id": "u9",  "start": 96.0,  "end": 101.3, "text": "It's my mom. She fell. I have to go — but I can't just leave this.","speaker": "B", "confidence": 0.92 },
      { "id": "u10", "start": 102.0, "end": 108.7, "text": "Sarah, go. The job will still be a decision tomorrow.",           "speaker": "A", "confidence": 0.94 },
      { "id": "u11", "start": 110.0, "end": 117.5, "text": "But if I take Singapore, I won't be here next time she falls.",   "speaker": "B", "confidence": 0.90 },
      { "id": "u12", "start": 150.0, "end": 158.2, "text": "Then maybe… that's already your answer.",                         "speaker": "A", "confidence": 0.95 },
      { "id": "u13", "start": 162.0, "end": 168.4, "text": "Yeah. Yeah, it is. Thank you, James.",                            "speaker": "B", "confidence": 0.93 }
