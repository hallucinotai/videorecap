# =============================================================================
# Video Recap Agent — Staging Environment Variables
# =============================================================================
# Copy to .env on the STAGING server (~/videorecap-staging/.env).
# NEVER commit the actual .env file to version control.
# All values MUST differ from production to ensure full isolation.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:STAGING_DB_PASSWORD@postgres:5432/video_recap

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=STAGING_MINIO_ACCESS_KEY
S3_SECRET_KEY=STAGING_MINIO_SECRET_KEY
S3_BUCKET=video-recaps
S3_REGION=us-east-1
S3_PUBLIC_ENDPOINT=http://staging.hallucinotai.com/storage

# --- JWT Auth ---
# Generate a DIFFERENT secret from production:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=STAGING_JWT_SECRET_CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=

# --- Stripe Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
WHISPER_MODEL_SIZE=small

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Video Recap Staging <noreply@yourdomain.com>
OTP_EXPIRY_MINUTES=10

# --- CORS ---
CORS_ORIGINS=["http://staging.hallucinotai.com"]

# --- File Upload ---
MAX_UPLOAD_SIZE_BYTES=2147483648

# --- Docker Port Bindings (staging) ---
# Different ports from production to avoid conflicts on same VPS
POSTGRES_PORT=127.0.0.1:5435
REDIS_PORT=127.0.0.1:6381
MINIO_API_PORT=127.0.0.1:9200
MINIO_CONSOLE_PORT=127.0.0.1:9201
BACKEND_PORT=127.0.0.1:8200
FRONTEND_PORT=127.0.0.1:3200

# --- MinIO Credentials (used in docker-compose minio service) ---
MINIO_ROOT_USER=STAGING_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=STAGING_MINIO_SECRET_KEY

# --- Postgres Credentials (used in docker-compose postgres service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=STAGING_DB_PASSWORD

# --- Feature Flags ---
ENABLE_USER_API_KEYS=true
API_KEY_ALLOWED_EMAILS=[]
ENABLE_TRANSLATION=false
DEBUG=true
DELETE_INPUT_VIDEO_ON_COMPLETE=true
