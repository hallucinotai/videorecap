# =============================================================================
# Video Recap Agent — Backend Environment Variables
# =============================================================================
# Copy to .env and fill in values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/video_recap

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=video-recaps
S3_REGION=us-east-1

# --- JWT Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=

# --- Stripe Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
WHISPER_MODEL_SIZE=small

# --- AssemblyAI Speaker Diarization ---
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
REQUIRE_ASSEMBLYAI_KEY=True
ENABLE_ASSEMBLYAI_DIARIZATION=true
ASSEMBLYAI_LANGUAGE_CODE=en

# --- OpenAI & AssemblyAI User API Keys ---
# Allow specific users to provide their own API keys instead of using system keys
ENABLE_USER_API_KEYS=false
# Comma-separated list of email addresses allowed to use their own OpenAI keys
API_KEY_ALLOWED_EMAILS=[]

# --- Development ---
# Typical localhost setup: preserves Celery recap tempfile dirs (/tmp/recap_<job>_...) after each job so you can open output/*/ files.
DEBUG=true
# Explicit override for pipeline tempfile cleanup (default: unset = preserve only when DEBUG is true).
# KEEP_PIPELINE_WORKING_DIR=false

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Video Recap <noreply@yourdomain.com>
OTP_EXPIRY_MINUTES=10

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- File Upload ---
MAX_UPLOAD_SIZE_BYTES=2147483648

# --- Storage retention ---
# Remove uploaded original from S3 after successful recap (output + intermediates kept until expiry)
DELETE_INPUT_VIDEO_ON_COMPLETE=true
