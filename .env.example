# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys

# Required: Your OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: GPT Model (default: gpt-4)
# Options: gpt-4, gpt-4-turbo, gpt-4o, gpt-3.5-turbo
model=gpt-4

# ----- AssemblyAI Speaker Diarization (OPTIONAL FEATURE)
# Enable speaker diarization in transcriptions
# Get your API key from: https://www.assemblyai.com/app/account
ENABLE_ASSEMBLYAI_DIARIZATION=false
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
ASSEMBLYAI_LANGUAGE_CODE=en

# ----- Docker Compose / Celery pipeline
# Uncomment for localhost debugging (keeps /tmp/recap_<job>_.../output after each job)
# DEBUG=true
# KEEP_PIPELINE_WORKING_DIR=true
